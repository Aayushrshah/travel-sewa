rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Travel Sewa client app — workspace isolation is enforced in the app via ownerAdminId.
    // Tighten these rules (e.g. require auth + App Check) before a public production launch.
    match /tickets/{id} {
      allow read, write: if true;
    }
    match /buses/{id} {
      allow read, write: if true;
    }
    match /routes/{id} {
      allow read, write: if true;
    }
    match /staff/{id} {
      allow read, write: if true;
    }
    match /expenses/{id} {
      allow read, write: if true;
    }
    match /seatLocks/{id} {
      allow read, write: if true;
    }
  }
}
